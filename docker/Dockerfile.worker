FROM ubuntu:22.04
RUN apt-get update && apt-get install -y g++ make && rm -rf /var/lib/apt/lists/*
WORKDIR /app
COPY runtime/main.cpp runtime/task.h runtime/task.cpp runtime/worker.h runtime/worker.cpp runtime/worker_pool.h runtime/worker_pool.cpp runtime/Makefile ./
RUN make
EXPOSE 9000
CMD ["./worker", "9000", "4"]
